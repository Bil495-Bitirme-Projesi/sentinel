<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- cms-server.local ve tüm subdomain'leri -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">cms-server.local</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">192.168.137.1</domain>
        <domain includeSubdomains="false">10.42.0.1</domain>
        <trust-anchors>
            <certificates src="@raw/server"/>
        </trust-anchors>
    </domain-config>
</network-security-config>

